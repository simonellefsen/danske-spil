# Copy to .env.local and fill locally. Do not commit real credentials.

DANSKESPIL_LOGIN_URL=https://danskespil.dk/oddset
DANSKESPIL_ODDSET_URL=https://danskespil.dk/oddset
DANSKESPIL_TIPS_URL=https://danskespil.dk/tips
DANSKESPIL_USERNAME=
DANSKESPIL_PASSWORD=
DANSKESPIL_TOTP_SECRET=

# Keep real-money placement disabled until the compliance gate is explicitly
# reviewed and a human-approval flow exists.
DANSKESPIL_ALLOW_REAL_MONEY_PLACEMENT=false
DANSKESPIL_MAX_SINGLE_STAKE_DKK=0
DANSKESPIL_MAX_DAILY_STAKE_DKK=0
DANSKESPIL_MAX_WEEKLY_STAKE_DKK=0

POSTGRES_APP_USER=danske_spil
POSTGRES_APP_PASSWORD=change-me
POSTGRES_DB=danske_spil
DATABASE_URL=postgres://danske_spil:change-me@danske-spil-postgres-rw.danske-spil.svc.cluster.local:5432/danske_spil

HERMES_API_SERVER_ENABLED=false
HERMES_API_SERVER_HOST=0.0.0.0
HERMES_API_SERVER_KEY=
HERMES_INFERENCE_PROVIDER=xai
HERMES_MODEL=grok-4
HERMES_DANSKESPIL_API_KEY=
HERMES_DANSKESPIL_MCP_URL=http://gambler-mcp.danske-spil:8610/mcp
